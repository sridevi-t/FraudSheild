  .fab{position:fixed;bottom:28px;right:28px;width:58px;height:58px;background:linear-gradient(135deg,var(--saffron),var(--saffron2));border-radius:50%;border:none;cursor:pointer;box-shadow:0 4px 20px rgba(255,107,0,.4);display:flex;align-items:center;justify-content:center;font-size:26px;z-index:8000;transition:all .2s}
  .fab:hover{transform:scale(1.1)}
  .fab-badge{position:absolute;top:-2px;right:-2px;width:18px;height:18px;background:var(--green);border-radius:50%;font-size:10px;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;border:2px solid #fff}
  .chat-win{position:fixed;bottom:98px;right:28px;width:360px;height:490px;background:#fff;border-radius:20px;box-shadow:0 8px 40px rgba(0,0,128,.2);z-index:8000;display:none;flex-direction:column;overflow:hidden}
  .chat-win.open{display:flex;animation:chatpop .3s cubic-bezier(.34,1.56,.64,1)}
  @keyframes chatpop{from{transform:scale(.8) translateY(20px);opacity:0}to{transform:scale(1) translateY(0);opacity:1}}
  .chat-head{background:var(--navy2);padding:16px 18px;display:flex;align-items:center;gap:10px}
  .chat-avatar{width:36px;height:36px;background:var(--saffron2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
  .chat-name{font-family:'Baloo 2',cursive;font-size:15px;font-weight:700;color:#fff}
  .chat-status-txt{font-size:11px;color:rgba(255,255,255,.55)}
  .chat-close{margin-left:auto;background:transparent;border:none;color:rgba(255,255,255,.6);font-size:20px;cursor:pointer}
  .chat-msgs{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;background:#F8F9FA}
  .msg{max-width:82%;padding:10px 14px;border-radius:14px;font-size:13px;line-height:1.55}
  .msg.bot{background:#fff;color:var(--text);border-bottom-left-radius:4px;box-shadow:0 1px 4px rgba(0,0,0,.08);align-self:flex-start}
  .msg.user{background:var(--navy2);color:#fff;border-bottom-right-radius:4px;align-self:flex-end}
  .msg.typing{background:#fff;color:var(--muted);font-style:italic;align-self:flex-start;box-shadow:0 1px 4px rgba(0,0,0,.08)}
  .chat-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 10px;background:#fff}
  .chip{padding:5px 12px;background:var(--cream);border:1px solid var(--border);border-radius:20px;font-size:11px;cursor:pointer;color:var(--navy2);font-weight:500;transition:all .15s}
  .chip:hover{background:rgba(255,107,0,.1);border-color:var(--saffron)}
  .chat-input-row{padding:12px 14px;border-top:1px solid var(--border);display:flex;gap:8px;background:#fff}
  .chat-input{flex:1;padding:9px 14px;border:1.5px solid var(--border);border-radius:24px;font-family:'DM Sans',sans-serif;font-size:13px;outline:none;background:var(--cream)}
  .chat-input:focus{border-color:var(--saffron2)}
  .chat-send{padding:9px 18px;background:var(--saffron);color:#fff;border:none;border-radius:24px;font-weight:600;cursor:pointer;font-size:13px;transition:background .15s}
  .chat-send:hover{background:var(--saffron2)}
  footer{background:var(--navy2);padding:16px 32px;margin-top:12px;text-align:center}
  footer p{font-size:12px;color:rgba(255,255,255,.4)}
  footer span{color:var(--saffron2)}
  ::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:#C5B8A8;border-radius:3px}
</style>
</head>
<body>
<div class="tricolor"></div>
<header>
  <div class="header-inner">
    <div class="logo-area">
      <div class="logo-icon">🛡️</div>
      <div>
        <div class="logo-main">Suraksha<span>Pay</span></div>
        <div class="logo-sub">AI-Powered Fraud Detection System</div>
      </div>
    </div>
    <div class="header-right">
      <div class="live-pill"><div class="live-dot"></div> Live Monitor</div>
      <div class="hdr-info"><div><strong id="hdr-time">00:00:00</strong></div><div>Random Forest + Groq AI</div></div>
    </div>
  </div>
</header>
<div class="stats-bar">
  <div class="stats-inner">
    <div class="stat-item"><span style="font-size:20px">📊</span><div><div class="stat-num" id="s-total">0</div><div class="stat-lbl">Total Analysed</div></div></div>
    <div class="stat-item"><span style="font-size:20px">✅</span><div><div class="stat-num" id="s-approved">0</div><div class="stat-lbl">Authorised</div></div></div>
    <div class="stat-item"><span style="font-size:20px">⚠️</span><div><div class="stat-num" id="s-review">0</div><div class="stat-lbl">Under Review</div></div></div>
    <div class="stat-item"><span style="font-size:20px">🚫</span><div><div class="stat-num" id="s-blocked">0</div><div class="stat-lbl">Blocked</div></div></div>
  </div>
</div>
<div class="main">
  <div>
    <div class="card">
      <div class="card-head">
        <div class="card-icon navy">🔗</div>
        <div><div class="card-title">Backend Connection</div><div class="card-sub">Paste ngrok URL from Colab Cell 6</div></div>
      </div>
      <div class="card-body">
        <div class="field"><label>ngrok URL</label><input type="text" id="api-url" placeholder="https://xxxx.ngrok-free.app"></div>
        <p style="font-size:11px;color:var(--muted)">🔑 Run Cell 6 in Colab → copy the printed URL → paste above</p>
      </div>
    </div>
    <div class="card">
      <div class="card-head">
        <div class="card-icon saffron">💳</div>
        <div><div class="card-title">Transaction Details</div><div class="card-sub">Enter payment information</div></div>
      </div>
      <div class="card-body">
        <div class="section-label">Quick Fill — Test Scenarios</div>
        <div class="preset-grid">
          <button class="preset p1" onclick="fill('normal')">🛒 Normal Purchase</button>
          <button class="preset p2" onclick="fill('online')">📱 UPI / Online</button>
          <button class="preset p3" onclick="fill('suspicious')">⚠️ Suspicious</button>
          <button class="preset p4" onclick="fill('fraud')">🚨 High Risk</button>
        </div>
        <div class="section-label">Payment Info</div>
        <div class="field"><label>Merchant Name</label><input type="text" id="merchant_name" value="Big Bazaar"></div>
        <div class="field"><label>Amount (₹ INR)</label><div class="rupee-wrap"><span class="rs">₹</span><input type="number" id="amount" value="850" min="0" step="0.01"></div></div>
        <div class="field-row">
          <div class="field"><label>Transaction Type</label><select id="is_online"><option value="0">In-Store / POS</option><option value="1">Online / UPI</option></select></div>
          <div class="field"><label>Card Age (days)</label><input type="number" id="card_age_days" value="365" min="1"></div>
        </div>
        <div class="section-label">Time & Location</div>
        <div class="field-row">
          <div class="field"><label>Hour (0–23)</label><input type="number" id="hour" value="14" min="0" max="23"></div>
          <div class="field"><label>Day of Week</label><select id="day_of_week"><option value="0">Monday</option><option value="1">Tuesday</option><option value="2">Wednesday</option><option value="3">Thursday</option><option value="4" selected>Friday</option><option value="5">Saturday</option><option value="6">Sunday</option></select></div>
        </div>
        <div class="field"><label>Distance from Registered Address (km)</label><input type="number" id="geo_distance_km" value="10" min="0"></div>
        <div class="section-label">Risk Signals</div>
        <div class="field-row">
          <div class="field"><label>Merchant Risk Score (0–1)</label><input type="number" id="merchant_risk" value="0.1" min="0" max="1" step="0.01"></div>
          <div class="field"><label>Transactions This Hour</label><input type="number" id="txn_per_hour" value="2" min="0"></div>
        </div>
        <button class="btn-analyze" id="analyze-btn" onclick="analyze()">⚡ Analyse Transaction</button>
        <button class="btn-auto" id="auto-btn" onclick="toggleAuto()">▶ Start Auto Simulation</button>
      </div>
    </div>
  </div>
  <div class="right-col">
    <div class="card">
      <div class="card-head">
        <div class="card-icon green">🛡️</div>
        <div><div class="card-title">Analysis Result</div><div class="card-sub" id="res-sub">Waiting for transaction...</div></div>
      </div>
      <div id="result-area">
        <div class="result-placeholder">
          <div class="placeholder-icon">🏦</div>
          <div style="color:var(--muted);font-size:13px">Submit a transaction to see the fraud analysis</div>
          <div style="color:var(--muted);font-size:11px;margin-top:4px">Powered by Random Forest + Isolation Forest + Groq LLaMA 3.3</div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-head">
        <div class="card-icon blue">📋</div>
        <div><div class="card-title">Transaction History</div><div class="card-sub">Recent analysed transactions</div></div>
        <button onclick="clearHistory()" style="margin-left:auto;padding:5px 12px;background:transparent;border:1px solid var(--border);border-radius:6px;font-size:11px;cursor:pointer;color:var(--muted);font-family:'DM Sans',sans-serif">Clear</button>
      </div>
      <div id="history-area"><div class="empty-log">No transactions analysed yet</div></div>
    </div>
  </div>
</div>
<footer><p><span>FRAUDSHIELD</span> — AI Fraud Detection &nbsp;|&nbsp; Python · Flask · Groq AI · scikit-learn &nbsp;|&nbsp; 🇮🇳 Made for India</p></footer>

<!-- FRAUD BLOCKED ALERT -->
<div class="overlay" id="fraud-overlay" style="display:none">
  <div class="alert-box">
    <div class="alert-hdr red"><div class="alert-siren">🚨</div><div class="alert-title">Fraudulent Activity Detected!</div><div class="alert-sub">Transaction has been automatically blocked</div></div>
    <div class="alert-body">
      <div class="alert-score red" id="al-score">--</div>
      <div class="alert-score-lbl">Fraud Probability Score</div>
      <div class="alert-row"><span class="alert-lbl">Merchant</span><span class="alert-val" id="al-merchant">--</span></div>
      <div class="alert-row"><span class="alert-lbl">Amount</span><span class="alert-val" id="al-amount">--</span></div>
      <div class="alert-row"><span class="alert-lbl">Time</span><span class="alert-val" id="al-time">--</span></div>
      <div class="alert-row"><span class="alert-lbl">Status</span><span class="alert-val" style="color:var(--red)">🚫 Transaction Blocked</span></div>
      <button class="alert-btn red" onclick="closeOverlay('fraud-overlay')">✅ Acknowledge & Block Transaction</button>
      <button class="alert-btn2" onclick="closeOverlay('fraud-overlay')">Escalate to Senior Analyst</button>
    </div>
  </div>
</div>

<!-- REVIEW ALERT -->
<div class="overlay" id="review-overlay" style="display:none">
  <div class="alert-box">
    <div class="alert-hdr orange"><div class="alert-siren">⚠️</div><div class="alert-title">Review Required</div><div class="alert-sub">Suspicious behaviour detected — manual review needed</div></div>
    <div class="alert-body">
      <div class="alert-score orange" id="rv-score">--</div>
      <div class="alert-score-lbl">Fraud Probability Score</div>
      <div class="alert-row"><span class="alert-lbl">Merchant</span><span class="alert-val" id="rv-merchant">--</span></div>
      <div class="alert-row"><span class="alert-lbl">Amount</span><span class="alert-val" id="rv-amount">--</span></div>
      <div class="alert-row"><span class="alert-lbl">Time</span><span class="alert-val" id="rv-time">--</span></div>
      <div class="alert-row"><span class="alert-lbl">Status</span><span class="alert-val" style="color:var(--amber)">⚠️ Under Review</span></div>
      <button class="alert-btn orange" onclick="closeOverlay('review-overlay')">👁️ Send to Review Queue</button>
      <button class="alert-btn2" onclick="closeOverlay('review-overlay')">Authorise Anyway</button>
    </div>
  </div>
</div>

<!-- CHATBOT -->
<button class="fab" onclick="toggleChat()" title="Ask SurakshaPay AI">🤖<div class="fab-badge">AI</div></button>
<div class="chat-win" id="chat-win">
  <div class="chat-head">
    <div class="chat-avatar">🛡️</div>
    <div><div class="chat-name">SurakshaPay AI Assistant</div><div class="chat-status-txt">● Online — Ask me about fraud detection</div></div>
    <button class="chat-close" onclick="toggleChat()">✕</button>
  </div>
  <div class="chat-msgs" id="chat-msgs">
    <div class="msg bot">👋 Hello! I am the SurakshaPay AI assistant. I can help you understand fraud scores, explain risk signals, and answer questions about transactions. How can I help you today?</div>
  </div>
  <div class="chat-chips" id="chat-chips">
    <div class="chip" onclick="quickAsk(this)">What is a fraud score?</div>
    <div class="chip" onclick="quickAsk(this)">How does the ML model work?</div>
    <div class="chip" onclick="quickAsk(this)">Common UPI fraud patterns</div>
    <div class="chip" onclick="quickAsk(this)">What is merchant risk?</div>
  </div>
  <div class="chat-input-row">
    <input class="chat-input" id="chat-input" placeholder="Ask about fraud detection..." onkeydown="if(event.key==='Enter')sendChat()">
    <button class="chat-send" onclick="sendChat()">Send</button>
  </div>
</div>

<script>
function tick(){document.getElementById('hdr-time').textContent=new Date().toTimeString().slice(0,8);}
tick();setInterval(tick,1000);
window.addEventListener('DOMContentLoaded',()=>{
  const o=window.location.origin;
  if(o&&!o.includes('null')&&!o.includes('file'))document.getElementById('api-url').value=o;
});
const PRESETS={
  normal:    {amount:850,   hour:14,day_of_week:4,merchant_risk:0.08,geo_distance_km:4,   txn_per_hour:1, card_age_days:730,is_online:0,merchant_name:'Big Bazaar'},
  online:    {amount:14999, hour:20,day_of_week:5,merchant_risk:0.18,geo_distance_km:0,   txn_per_hour:2, card_age_days:365,is_online:1,merchant_name:'Flipkart'},
  suspicious:{amount:48000, hour:2, day_of_week:6,merchant_risk:0.55,geo_distance_km:480, txn_per_hour:7, card_age_days:18, is_online:1,merchant_name:'Unknown Seller'},
  fraud:     {amount:850000,hour:3, day_of_week:0,merchant_risk:0.93,geo_distance_km:2200,txn_per_hour:15,card_age_days:3,  is_online:1,merchant_name:'Offshore Store'},
};
function fill(key){Object.entries(PRESETS[key]).forEach(([k,v])=>{const el=document.getElementById(k);if(el)el.value=v;});}
function getData(){
  return{
    amount:         parseFloat(document.getElementById('amount').value)||100,
    hour:           parseInt(document.getElementById('hour').value)||12,
    day_of_week:    parseInt(document.getElementById('day_of_week').value),
    merchant_risk:  parseFloat(document.getElementById('merchant_risk').value)||0.1,
    geo_distance_km:parseFloat(document.getElementById('geo_distance_km').value)||10,
    txn_per_hour:   parseInt(document.getElementById('txn_per_hour').value)||1,
    card_age_days:  parseInt(document.getElementById('card_age_days').value)||365,
    is_online:      parseInt(document.getElementById('is_online').value),
    merchant_name:  document.getElementById('merchant_name').value||'Unknown',
  };
}
let history=[],autoTimer=null,autoOn=false,busy=false;
async function analyze(){
  if(busy)return;
  const base=document.getElementById('api-url').value.trim().replace(/\/$/,'');
  if(!base){alert('Please paste your ngrok URL first.');return;}
  busy=true;
  const btn=document.getElementById('analyze-btn');
  btn.disabled=true;btn.textContent='⏳ Analysing...';btn.classList.add('loading');
  document.getElementById('res-sub').textContent='Analysing...';
  document.getElementById('result-area').innerHTML='<div class="dots"><div class="dot"></div><div class="dot"></div><div class="dot"></div>Running ML model and Groq AI analysis...</div>';
  try{
    const res=await fetch(base+'/analyze',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(getData())});
    const d=await res.json();
    if(!d.success)throw new Error(d.error);
    renderResult(d);addHistory(d);updateStats();showAlert(d);
  }catch(e){
    alert('Error: '+e.message);
    document.getElementById('result-area').innerHTML='<div class="result-placeholder"><div style="font-size:36px">⚠️</div><div style="color:var(--red);font-size:13px">'+e.message+'</div></div>';
  }finally{
    busy=false;btn.disabled=false;btn.textContent='⚡ Analyse Transaction';btn.classList.remove('loading');
  }
}
function renderResult(d){
  const cls={high:'blocked',medium:'review',low:'approved'}[d.risk];
  const emj={high:'🚫',medium:'⚠️',low:'✅'}[d.risk];
  const lbl={high:'BLOCKED',medium:'REVIEW',low:'AUTHORISED'}[d.risk];
  const amt=parseFloat(d.amount).toLocaleString('en-IN',{minimumFractionDigits:2});
  const feats=Object.entries(d.top_features||{}).map(([k,v])=>'<div class="risk-tag">'+k.replace(/_/g,' ')+' · '+v+'</div>').join('');
  document.getElementById('res-sub').textContent='Txn #'+d.id+' · '+d.merchant+' · '+d.timestamp;
  document.getElementById('result-area').innerHTML=`
    <div class="result-body">
      <div class="verdict-row">
        <div class="verdict-left">
          <div class="verdict-emoji">${emj}</div>
          <div><div class="verdict-text ${cls}">${lbl}</div><div class="verdict-sub">₹${amt} at ${d.merchant}</div></div>
        </div>
        <div class="score-ring ${cls}"><span>${(d.score*100).toFixed(0)}</span><span class="score-ring-lbl">SCORE</span></div>
      </div>
      <div class="bar-wrap">
        <div class="bar-labels"><span>Fraud Probability</span><span>${(d.score*100).toFixed(1)}%</span></div>
        <div class="bar-track"><div class="bar-fill ${cls}" style="width:${(d.score*100).toFixed(1)}%"></div></div>
        <div class="bar-labels"><span>0% Safe</span><span>40% Review</span><span>70% Block</span></div>
      </div>
      <div class="info-grid">
        <div class="info-cell"><div class="info-lbl">Amount</div><div class="info-val">₹${amt}</div></div>
        <div class="info-cell"><div class="info-lbl">Merchant</div><div class="info-val">${d.merchant}</div></div>
        <div class="info-cell"><div class="info-lbl">Fraud Score</div><div class="info-val">${(d.score*100).toFixed(2)}%</div></div>
        <div class="info-cell"><div class="info-lbl">Decision</div><div class="info-val">${lbl}</div></div>
      </div>
      <div><div class="section-label" style="margin-bottom:8px">Top Risk Factors</div><div class="risk-tags">${feats}</div></div>
      <div class="ai-box"><div class="ai-lbl">🤖 Groq AI Analysis</div><div class="ai-text">${(d.explanation||'').trim()}</div></div>
    </div>`;
}
function showAlert(d){
  const amt='₹'+parseFloat(d.amount).toLocaleString('en-IN',{minimumFractionDigits:2});
  if(d.risk==='high'){
    document.getElementById('al-score').textContent=(d.score*100).toFixed(1)+'%';
    document.getElementById('al-merchant').textContent=d.merchant;
    document.getElementById('al-amount').textContent=amt;
    document.getElementById('al-time').textContent=d.timestamp;
    document.getElementById('fraud-overlay').style.display='flex';
  }else if(d.risk==='medium'){
    document.getElementById('rv-score').textContent=(d.score*100).toFixed(1)+'%';
    document.getElementById('rv-merchant').textContent=d.merchant;
    document.getElementById('rv-amount').textContent=amt;
    document.getElementById('rv-time').textContent=d.timestamp;
    document.getElementById('review-overlay').style.display='flex';
  }
}
function closeOverlay(id){document.getElementById(id).style.display='none';}
document.addEventListener('click',e=>{
  ['fraud-overlay','review-overlay'].forEach(id=>{const el=document.getElementById(id);if(e.target===el)el.style.display='none';});
});
function addHistory(d){
  history.unshift(d);
  const area=document.getElementById('history-area');
  const cls={high:'blocked',medium:'review',low:'approved'}[d.risk];
  const lbl={high:'BLOCKED',medium:'REVIEW',low:'AUTHORISED'}[d.risk];
  const emj={high:'🚫',medium:'⚠️',low:'✅'}[d.risk];
  const amt=parseFloat(d.amount).toLocaleString('en-IN',{minimumFractionDigits:2});
  if(!document.getElementById('hist-tbl')){
    area.innerHTML='<table id="hist-tbl"><thead><tr><th>#</th><th>Time</th><th>Merchant</th><th>Amount (₹)</th><th>Score</th><th>Decision</th></tr></thead><tbody id="hist-body"></tbody></table>';
  }
  const tr=document.createElement('tr');tr.className='new';
  tr.innerHTML='<td style="color:var(--muted)">'+d.id+'</td><td style="color:var(--muted)">'+d.timestamp+'</td><td><strong>'+d.merchant+'</strong></td><td>₹'+amt+'</td><td><span class="sc '+cls+'">'+(d.score*100).toFixed(1)+'%</span></td><td><span class="badge '+cls+'">'+emj+' '+lbl+'</span></td>';
  document.getElementById('hist-body').insertBefore(tr,document.getElementById('hist-body').firstChild);
}
function clearHistory(){history=[];document.getElementById('history-area').innerHTML='<div class="empty-log">No transactions analysed yet</div>';updateStats();}
function updateStats(){
  document.getElementById('s-total').textContent=history.length;
  document.getElementById('s-approved').textContent=history.filter(t=>t.risk==='low').length;
  document.getElementById('s-review').textContent=history.filter(t=>t.risk==='medium').length;
  document.getElementById('s-blocked').textContent=history.filter(t=>t.risk==='high').length;
}
const AUTO=['normal','normal','online','suspicious','fraud'];
function toggleAuto(){
  const btn=document.getElementById('auto-btn');
  if(autoOn){clearInterval(autoTimer);autoOn=false;btn.textContent='▶ Start Auto Simulation';btn.classList.remove('running');}
  else{autoOn=true;btn.textContent='⏹ Stop Simulation';btn.classList.add('running');autoTimer=setInterval(()=>{fill(AUTO[Math.floor(Math.random()*AUTO.length)]);analyze();},2500);}
}
let chatOpen=false;
function toggleChat(){chatOpen=!chatOpen;document.getElementById('chat-win').classList.toggle('open',chatOpen);}
function getStats(){
  return{total:history.length,blocked:history.filter(t=>t.risk==='high').length,review:history.filter(t=>t.risk==='medium').length,approved:history.filter(t=>t.risk==='low').length,lastTxn:history[0]?'₹'+parseFloat(history[0].amount).toLocaleString('en-IN')+' at '+history[0].merchant:'None yet'};
}
async function sendChat(){
  const input=document.getElementById('chat-input');
  const msg=input.value.trim();if(!msg)return;
  const base=document.getElementById('api-url').value.trim().replace(/[/]/$/,'');
  if(!base){alert('Set ngrok URL first.');return;}
  input.value='';
  document.getElementById('chat-chips').style.display='none';
