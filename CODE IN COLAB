@app.route("/analyze", methods=["POST"])
def analyze():
    data = request.json
    try:
        X_new   = engineer_features(data)
        X_new_s = scaler.transform(X_new)
        rf_p    = float(rf.predict_proba(X_new_s)[0][1])
        iso_s   = float(-iso.score_samples(X_new_s)[0])
        iso_n   = max(0.0, min(1.0, (iso_s - 0.3) / 0.4))
        score   = round(0.7 * rf_p + 0.3 * iso_n, 4)
        decision = "BLOCKED" if score > 0.7 else ("REVIEW" if score > 0.4 else "APPROVED")
        risk     = "high"    if score > 0.7 else ("medium" if score > 0.4 else "low")
        top_feat = get_top_features(X_new_s)
        expl = explain(data, score, top_feat) if score > 0.25 else \
               "* Transaction looks legitimate with no major anomalies.\n* All indicators within normal limits.\n* No action required — authorise the transaction."
        record = {
            "id": len(transaction_log)+1, "timestamp": time.strftime("%H:%M:%S"),
