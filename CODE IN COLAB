import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler

np.random.seed(42)
N = 5000

def generate_data(n):
    df = pd.DataFrame({
        'amount':          np.random.exponential(120, n),
        'hour':            np.random.randint(0, 24, n),
        'day_of_week':     np.random.randint(0, 7, n),
        'merchant_risk':   np.random.beta(2, 8, n),
        'geo_distance_km': np.random.exponential(50, n),
        'txn_per_hour':    np.random.poisson(2, n),
        'card_age_days':   np.random.randint(1, 3650, n),
        'is_online':       np.random.binomial(1, 0.4, n),
    })
    fraud_mask = np.random.random(n) < 0.05
    df.loc[fraud_mask, 'amount']          *= np.random.uniform(3, 10, fraud_mask.sum())
    df.loc[fraud_mask, 'merchant_risk']   += 0.5
    df.loc[fraud_mask, 'geo_distance_km'] *= np.random.uniform(5, 20, fraud_mask.sum())
    df.loc[fraud_mask, 'txn_per_hour']    += np.random.randint(5, 15, fraud_mask.sum())
    df['is_fraud'] = fraud_mask.astype(int)
    return df

df = generate_data(N)
print(f"✅ Dataset ready: {len(df)} rows | Fraud rate: {df['is_fraud'].mean()*100:.1f}%")
df.head()

def add_features(df):
    df = df.copy()
    df['amount_log']    = np.log1p(df['amount'])
    df['is_night']      = ((df['hour'] < 6) | (df['hour'] > 22)).astype(int)
    df['is_weekend']    = (df['day_of_week'] >= 5).astype(int)
    df['high_velocity'] = (df['txn_per_hour'] > 5).astype(int)
    df['new_card']      = (df['card_age_days'] < 30).astype(int)
    df['amount_zscore'] = df.groupby('hour')['amount'].transform(
        lambda x: (x - x.mean()) / (x.std() + 1e-8)
    )
    return df

df = add_features(df)

FEATURES = ['amount_log','amount_zscore','hour','is_night','is_weekend',
            'merchant_risk','geo_distance_km','txn_per_hour','high_velocity',
            'card_age_days','new_card','is_online']

print("✅ Features ready:", FEATURES)

from sklearn.ensemble import RandomForestClassifier, IsolationForest
from sklearn.model_selection import train_test_split
from sklearn.metrics import classification_report, roc_auc_score, confusion_matrix
from imblearn.over_sampling import SMOTE
import matplotlib.pyplot as plt
import seaborn as sns

X = df[FEATURES]
y = df['is_fraud']

X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.2, stratify=y, random_state=42
)

sm = SMOTE(random_state=42)
X_res, y_res = sm.fit_resample(X_train, y_train)

scaler = StandardScaler()
X_res_s  = scaler.fit_transform(X_res)
X_test_s = scaler.transform(X_test)

rf = RandomForestClassifier(n_estimators=200, max_depth=12,
                            class_weight='balanced', random_state=42)
rf.fit(X_res_s, y_res)
rf_proba = rf.predict_proba(X_test_s)[:, 1]

iso = IsolationForest(contamination=0.05, random_state=42)
iso.fit(X_res_s)
iso_scores      = -iso.score_samples(X_test_s)
iso_scores_norm = (iso_scores - iso_scores.min()) / (iso_scores.max() - iso_scores.min())

final_score = 0.7 * rf_proba + 0.3 * iso_scores_norm
final_pred  = (final_score > 0.5).astype(int)

print("=== Ensemble Model ===")
print(classification_report(y_test, final_pred))
print(f"ROC-AUC: {roc_auc_score(y_test, final_score):.4f}")

cm = confusion_matrix(y_test, final_pred)
plt.figure(figsize=(6,4))
sns.heatmap(cm, annot=True, fmt='d', cmap='Oranges',
            xticklabels=['Legit','Fraud'], yticklabels=['Legit','Fraud'])
plt.title('Confusion Matrix')
plt.tight_layout(); plt.show()
print("✅ Model trained successfully")

from sklearn.metrics import roc_curve
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

importances = pd.Series(rf.feature_importances_, index=FEATURES).sort_values(ascending=True)
importances.plot(kind='barh', ax=axes[0], color='#FF6B00')
axes[0].set_title('Feature Importances')
axes[0].set_xlabel('Importance')

fpr, tpr, _ = roc_curve(y_test, final_score)
axes[1].plot(fpr, tpr, color='#000080', lw=2,
             label=f'AUC = {roc_auc_score(y_test, final_score):.3f}')
axes[1].plot([0,1],[0,1],'k--',lw=1)
axes[1].set(xlabel='False Positive Rate', ylabel='True Positive Rate', title='ROC Curve')
axes[1].legend()
plt.tight_layout(); plt.show()
print("✅ Charts displayed")

