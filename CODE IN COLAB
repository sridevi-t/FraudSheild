@app.route("/chat", methods=["POST"])
def chat():
    data    = request.json
    msg     = data.get("message", "")
    context = data.get("context", {})
    prompt  = f"""You are FRAUDSHIELD AI, a helpful fraud detection assistant for an Indian payment platform.
Keep answers to 2-3 sentences. Use Rs. for amounts. Be clear and practical. Use British English (analyse, authorise, behaviour).
System stats: {json.dumps(context)}
User question: {msg}"""
    try:
        r = groq_client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=[{"role": "user", "content": prompt}],
            max_tokens=180, temperature=0.4,
        )
        return jsonify({"reply": r.choices[0].message.content.strip()})
    except Exception as e:
        return jsonify({"reply": f"Error: {str(e)}"}), 500

@app.route("/stats")
def stats():
    if not transaction_log:
        return jsonify({"total":0,"blocked":0,"review":0,"approved":0})
    total   = len(transaction_log)
    blocked = sum(1 for t in transaction_log if t["decision"]=="BLOCKED")
    review  = sum(1 for t in transaction_log if t["decision"]=="REVIEW")
    return jsonify({"total":total,"blocked":blocked,"review":review,"approved":total-blocked-review})

