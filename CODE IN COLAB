def engineer_features(raw):
    df = pd.DataFrame([raw])
    df['amount_log']    = np.log1p(df['amount'])
    df['is_night']      = ((df['hour'] < 6) | (df['hour'] > 22)).astype(int)
    df['is_weekend']    = (df['day_of_week'] >= 5).astype(int)
    df['high_velocity'] = (df['txn_per_hour'] > 5).astype(int)
    df['new_card']      = (df['card_age_days'] < 30).astype(int)
    df['amount_zscore'] = (df['amount_log'] - 5.0) / 2.0
    return df[FEATURES]

def get_top_features(txn_s, n=4):
    scores = rf.feature_importances_ * np.abs(txn_s[0])
    idx    = scores.argsort()[::-1][:n]
    return {FEATURES[i]: round(float(scores[i]), 4) for i in idx}

def explain(txn_raw, score, top_feat):
    decision = "BLOCKED" if score > 0.7 else ("REVIEW" if score > 0.4 else "APPROVED")
    prompt = f"""You are a concise fraud analyst AI for an Indian payment platform.
Transaction: {json.dumps({k: round(v,2) if isinstance(v,float) else v for k,v in txn_raw.items()})}
Fraud score: {score:.3f} -> Decision: {decision}
Top risk features: {json.dumps(top_feat)}
Reply in exactly 3 bullet points using * character:
* Decision summary (mention the INR amount)
* Top 2 risk signals in plain English
* Recommended action for the analyst
Max 90 words."""
    try:
        r = groq_client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=[{"role": "user", "content": prompt}],
            max_tokens=220, temperature=0.25,
        )
        return r.choices[0].message.content.strip()
    except Exception as e:
        return f"* AI explanation unavailable.\n* Error: {str(e)}\n* Check Groq API key."

